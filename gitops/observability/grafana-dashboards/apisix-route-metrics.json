      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(apisix_http_status{code=~\"5..\", route=\"api-route\"}[5m])) / sum(rate(apisix_http_status{route=\"api-route\"}[5m])) * 100",

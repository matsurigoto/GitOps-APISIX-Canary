{
  "annotations": {
    "list": []
  },
  "editable": true,
  "panels": [
    {
      "title": "QPS by Route",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(apisix_http_status{route=\"api-route\"}[5m]))",
          "legendFormat": "Stable (api-route)"
        },
        {
          "expr": "sum(rate(apisix_http_status{route=\"api-route-canary\"}[5m]))",
          "legendFormat": "Canary (api-route-canary)"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Stable (api-route)" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Canary (api-route-canary)" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "title": "HTTP Status by Route",
      "type": "timeseries",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "sum(rate(apisix_http_status{route=\"api-route\"}[5m])) by (code)",
          "legendFormat": "Stable - HTTP {{code}}"
        },
        {
          "expr": "sum(rate(apisix_http_status{route=\"api-route-canary\"}[5m])) by (code)",
          "legendFormat": "Canary - HTTP {{code}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      }
    },

{
  "annotations": { "list": [] },
  "editable": true,
  "panels": [
    {
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"demo-api\"}[5m])) by (uri, method, status)",
          "legendFormat": "{{method}} {{uri}} [{{status}}]"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "HTTP Request Duration (P95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_server_requests_seconds_bucket{application=\"demo-api\"}[5m])) by (le, uri))",
          "legendFormat": "{{uri}} P95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "JVM Heap Memory",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{application=\"demo-api\", area=\"heap\"}",
          "legendFormat": "{{id}} used"
        },
        {
          "expr": "jvm_memory_max_bytes{application=\"demo-api\", area=\"heap\"}",
          "legendFormat": "{{id}} max"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "title": "JVM Non-Heap Memory",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "jvm_memory_used_bytes{application=\"demo-api\", area=\"nonheap\"}",
          "legendFormat": "{{id}} used"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "title": "GC Pause Duration",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(jvm_gc_pause_seconds_sum{application=\"demo-api\"}[5m]) / rate(jvm_gc_pause_seconds_count{application=\"demo-api\"}[5m])",
          "legendFormat": "{{action}} {{cause}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Live Threads",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "jvm_threads_live_threads{application=\"demo-api\"}",
          "legendFormat": "Live"
        },
        {
          "expr": "jvm_threads_daemon_threads{application=\"demo-api\"}",
          "legendFormat": "Daemon"
        },
        {
          "expr": "jvm_threads_peak_threads{application=\"demo-api\"}",
          "legendFormat": "Peak"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "CPU Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "process_cpu_usage{application=\"demo-api\"}",
          "legendFormat": "Process CPU"
        },
        {
          "expr": "system_cpu_usage{application=\"demo-api\"}",
          "legendFormat": "System CPU"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" } }
    },
    {
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "process_uptime_seconds{application=\"demo-api\"}",
          "legendFormat": "Uptime"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Version by Instance",
      "type": "table",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "count by (version, instance) (http_server_requests_seconds_count{application=\"demo-api\"})",
          "legendFormat": "",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "organize", "options": { "excludeByName": { "Time": true, "Value": true }, "renameByName": { "instance": "Instance", "version": "Version" } } }
      ]
    },
    {
      "title": "Thread States",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "jvm_threads_states_threads{application=\"demo-api\", state=\"runnable\"}",
          "legendFormat": "Runnable"
        },
        {
          "expr": "jvm_threads_states_threads{application=\"demo-api\", state=\"blocked\"}",
          "legendFormat": "Blocked"
        },
        {
          "expr": "jvm_threads_states_threads{application=\"demo-api\", state=\"waiting\"}",
          "legendFormat": "Waiting"
        },
        {
          "expr": "jvm_threads_states_threads{application=\"demo-api\", state=\"timed-waiting\"}",
          "legendFormat": "Timed-Waiting"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "Logback Events (Error / Warn)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(increase(logback_events_total{application=\"demo-api\", level=\"error\"}[5m]))",
          "legendFormat": "ERROR"
        },
        {
          "expr": "sum(increase(logback_events_total{application=\"demo-api\", level=\"warn\"}[5m]))",
          "legendFormat": "WARN"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          { "matcher": { "id": "byName", "options": "ERROR" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "WARN" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
        ]
      }
    },
    {
      "title": "GC Memory Allocation Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(jvm_gc_memory_allocated_bytes_total{application=\"demo-api\"}[5m])",
          "legendFormat": "Allocation Rate"
        },
        {
          "expr": "rate(jvm_gc_memory_promoted_bytes_total{application=\"demo-api\"}[5m])",
          "legendFormat": "Promotion Rate"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "Bps" } }
    },
    {
      "title": "JVM Buffer Pools",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 40 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "jvm_buffer_memory_used_bytes{application=\"demo-api\"}",
          "legendFormat": "{{id}} used"
        },
        {
          "expr": "jvm_buffer_total_capacity_bytes{application=\"demo-api\"}",
          "legendFormat": "{{id}} capacity"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "title": "Class Loading",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 48 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "jvm_classes_loaded_classes{application=\"demo-api\"}",
          "legendFormat": "Loaded"
        },
        {
          "expr": "rate(jvm_classes_unloaded_classes_total{application=\"demo-api\"}[5m])",
          "legendFormat": "Unloaded Rate"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "File Descriptors",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 48 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "process_files_open_files{application=\"demo-api\"}",
          "legendFormat": "Open FDs"
        },
        {
          "expr": "process_files_max_files{application=\"demo-api\"}",
          "legendFormat": "Max FDs"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "Tomcat Threads",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 56 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "tomcat_threads_busy_threads{application=\"demo-api\"}",
          "legendFormat": "Busy"
        },
        {
          "expr": "tomcat_threads_current_threads{application=\"demo-api\"}",
          "legendFormat": "Current"
        },
        {
          "expr": "tomcat_threads_config_max_threads{application=\"demo-api\"}",
          "legendFormat": "Max"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "HTTP Request Duration (P99 by URI)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 56 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_requests_seconds_bucket{application=\"demo-api\"}[5m])) by (le, uri))",
          "legendFormat": "{{uri}} P99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ],
  "schemaVersion": 39,
  "tags": ["spring-boot", "jvm"],
  "time": { "from": "now-1h", "to": "now" },
  "title": "Spring Boot Metrics",
  "uid": "spring-boot-metrics"
}

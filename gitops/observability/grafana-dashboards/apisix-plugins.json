{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Active Plugins",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "count(apisix_http_status{plugin!=\"\"})",
          "legendFormat": "Plugins"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "title": "OpenTelemetry Traces Exported",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(apisix_http_status{plugin=\"opentelemetry\"}[5m]))",
          "legendFormat": "Traces/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Prometheus Metrics Scraped",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(apisix_http_status{route=~\".*prometheus.*\"}[5m]))",
          "legendFormat": "Scrapes/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "OPA Policy Evaluations",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(apisix_http_status{plugin=\"opa\"}[5m]))",
          "legendFormat": "Evals/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Traffic Split Plugin Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(apisix_http_status{plugin=\"traffic-split\"}[5m])) by (route)",
          "legendFormat": "{{route}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Proxy Cache Hit Rate",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(apisix_http_status{cache_status=\"HIT\"}[5m])) / sum(rate(apisix_http_status[5m])) * 100",
          "legendFormat": "Cache Hit %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 30 },
              { "color": "green", "value": 70 }
            ]
          }
        }
      }
    },
    {
      "title": "Plugin Execution Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(apisix_http_latency_bucket{type=\"apisix\"}[5m])) by (le, plugin))",
          "legendFormat": "{{plugin}} P95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "title": "Request Validation Plugin",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(apisix_http_status{plugin=\"request-validation\", code=\"200\"}[5m]))",
          "legendFormat": "Valid"
        },
        {
          "expr": "sum(rate(apisix_http_status{plugin=\"request-validation\", code=\"400\"}[5m]))",
          "legendFormat": "Invalid"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Fault Injection Activity",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(apisix_http_status{plugin=\"fault-injection\"}[5m])) by (code)",
          "legendFormat": "HTTP {{code}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "CORS Plugin Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(apisix_http_status{plugin=\"cors\"}[5m])) by (route)",
          "legendFormat": "{{route}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Proxy Rewrite Plugin",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(apisix_http_status{plugin=\"proxy-rewrite\"}[5m]))",
          "legendFormat": "Rewrites/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Redirect Plugin",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(apisix_http_status{plugin=\"redirect\"}[5m]))",
          "legendFormat": "Redirects/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Response Rewrite Plugin",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(apisix_http_status{plugin=\"response-rewrite\"}[5m]))",
          "legendFormat": "Rewrites/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Serverless Functions",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(apisix_http_status{plugin=~\"serverless.*\"}[5m]))",
          "legendFormat": "Executions/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    }
  ],
  "schemaVersion": 39,
  "tags": ["apisix", "plugins"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "APISIX Plugin Metrics",
  "uid": "apisix-plugins"
}

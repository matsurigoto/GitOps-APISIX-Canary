{
  "annotations": {
    "list": []
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Rate Limit Rejections",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(apisix_http_status{code=\"429\"}[5m]))",
          "legendFormat": "Rate Limited"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 100 }
            ]
          }
        }
      }
    },
    {
      "title": "IP Restriction Blocks",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(apisix_http_status{code=\"403\"}[5m]))",
          "legendFormat": "Blocked"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 50 }
            ]
          }
        }
      }
    },
    {
      "title": "Auth Failures",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(apisix_http_status{code=\"401\"}[5m]))",
          "legendFormat": "Unauthorized"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      }
    },
    {
      "title": "Bad Requests",
      "type": "stat",
      "gridPos": { "h": 5, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(apisix_http_status{code=\"400\"}[5m]))",
          "legendFormat": "Bad Request"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Rate Limit Activity by Route",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(apisix_http_status{code=\"429\"}[5m])) by (route)",
          "legendFormat": "{{route}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Security Blocks by Type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 5 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(apisix_http_status{code=\"401\"}[5m]))",
          "legendFormat": "401 Unauthorized"
        },
        {
          "expr": "sum(rate(apisix_http_status{code=\"403\"}[5m]))",
          "legendFormat": "403 Forbidden"
        },
        {
          "expr": "sum(rate(apisix_http_status{code=\"429\"}[5m]))",
          "legendFormat": "429 Rate Limited"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Shared Dict Usage - Rate Limiting",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "(apisix_shared_dict_capacity_bytes{name=\"plugin-limit-req\"} - apisix_shared_dict_free_space_bytes{name=\"plugin-limit-req\"}) / apisix_shared_dict_capacity_bytes{name=\"plugin-limit-req\"} * 100",
          "legendFormat": "limit-req"
        },
        {
          "expr": "(apisix_shared_dict_capacity_bytes{name=\"plugin-limit-count\"} - apisix_shared_dict_free_space_bytes{name=\"plugin-limit-count\"}) / apisix_shared_dict_capacity_bytes{name=\"plugin-limit-count\"} * 100",
          "legendFormat": "limit-count"
        },
        {
          "expr": "(apisix_shared_dict_capacity_bytes{name=\"plugin-limit-conn\"} - apisix_shared_dict_free_space_bytes{name=\"plugin-limit-conn\"}) / apisix_shared_dict_capacity_bytes{name=\"plugin-limit-conn\"} * 100",
          "legendFormat": "limit-conn"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "title": "Top Blocked IPs",
      "type": "table",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "topk(10, sum(rate(apisix_http_status{code=\"403\"}[5m])) by (remote_addr))",
          "legendFormat": "{{remote_addr}}",
          "format": "table"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Auth Attempts by Route",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(apisix_http_status{code=\"401\"}[5m])) by (route)",
          "legendFormat": "{{route}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Security Event Timeline",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 21 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(apisix_http_status{code=~\"40[0139]\"}[1m])) by (code, route)",
          "legendFormat": "{{route}} - {{code}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Request Validation Errors",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(apisix_http_status{code=\"400\"}[5m]))",
          "legendFormat": "Validation Errors"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "CORS Rejections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 29 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(apisix_http_status{code=\"403\", route=~\".*cors.*\"}[5m]))",
          "legendFormat": "CORS Blocks"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    }
  ],
  "schemaVersion": 39,
  "tags": ["apisix", "security", "rate-limiting"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
